APP_NAME=Яндекс Календарь
BIND_ADDRESS=127.0.0.1
HTTP_PORT=8083
SECRET_KEY=replace-with-a-long-random-secret
APP_USERNAME=admin
APP_PASSWORD=change-me
# По умолчанию парольный вход выключен при SSO_ENABLED=true.
PASSWORD_LOGIN_ENABLED=false

# Postgres. Приоритет у DATABASE_URL/database_url, потом у отдельных POSTGRES_* полей.
# DATABASE_URL=postgresql://app_user:app_password@postgres-host:5432/calendar_viewer
# database_url=postgresql://app_user:app_password@postgres-host:5432/calendar_viewer
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=calendar_viewer
POSTGRES_USER=calendar_viewer
POSTGRES_PASSWORD=change-me

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_OAUTH_URL=https://oauth.yandex.ru/token
YANDEX_CALENDAR_API_BASE=https://cloud-api.yandex.net/v1/calendar

DEFAULT_TIME_ZONE=Asia/Yekaterinburg
MAX_CALENDAR_DAYS=31
REQUEST_TIMEOUT=30

SSO_ENABLED=true
SSO_PROVIDER_NAME=SSO
SSO_AUTHORIZATION_URL=https://login.example.com/realms/example/protocol/openid-connect/auth
SSO_TOKEN_URL=https://login.example.com/realms/example/protocol/openid-connect/token
SSO_USERINFO_URL=https://login.example.com/realms/example/protocol/openid-connect/userinfo
SSO_CLIENT_ID=client-id
SSO_CLIENT_SECRET=client-secret
SSO_REDIRECT_URI=http://localhost:8083/sso/callback
SSO_SCOPES=openid email profile
